@model WorldCupBetting.Web.ViewModels.LeaderboardViewModel
@{
    ViewData["Title"] = "Leader Board";
}

<h1 class="h4 mb-3">Leader Board</h1>

<div class="table-responsive">
    <table class="table table-bordered table-sm align-middle">
        <thead>
            <tr>
                <th>Thứ hạng</th>
                <th>Tên hiển thị</th>
                <th>Số trận đoán đúng</th>
                <th>Số trận đoán sai</th>
                <th>Số tiền cúng</th>
                <th>Danh hiệu</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td>@row.Rank</td>
                <td>@row.DisplayName</td>
                <td>@row.CorrectPredictions</td>
                <td>@row.WrongPredictions</td>
                <td>@row.TotalAmount</td>
                <td>@(string.IsNullOrWhiteSpace(row.Title) ? "-" : row.Title)</td>
            </tr>
        }
        </tbody>
    </table>
</div>
